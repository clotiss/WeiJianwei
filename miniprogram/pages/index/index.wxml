<!--
============================================================================
首页 — 政策文件列表 + 分类筛选（WXML 模板）
============================================================================

WXML 是微信小程序的模板语言，类似 HTML 但有微信特有的语法：
- wx:if / wx:else → 条件渲染（值为 false 时元素不渲染到 DOM）
- wx:for / wx:key → 列表渲染（类似 Vue 的 v-for / React 的 map）
- {{}} → 数据绑定（单向绑定，从 JS data 到模板）
- bindtap / bindinput → 事件绑定（用户操作 → 触发 JS 方法）
- data-* → 向事件处理函数传递自定义参数

页面布局（从上到下）：
  顶部搜索栏 + 收藏/订阅按钮
  → 最新发布时间
  → 分类标签（双行横向滚动）
  → 文件类型切换栏
  → 文件列表（卡片形式）
  → 加载更多 / 查看更多
-->

<view class="container">
  <!-- ===== 顶部栏：搜索框 + 收藏 + 订阅 ===== -->
  <view class="top-bar">
    <!-- 搜索框（点击跳转搜索页） -->
    <view class="search-box" bindtap="goSearch">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索标题、发文机构...</text>
    </view>
    <!-- 收藏按钮 -->
    <view class="fav-btn" bindtap="goFavorites">收藏</view>
    <!-- 订阅消息按钮 -->
    <view class="fav-btn" bindtap="openSubscribe">订阅</view>
  </view>

  <!-- ===== 最近发布时间 ===== -->
  <view class="update-time" wx:if="{{latestUpdate}}">
    🕐 最新发布文件：{{latestUpdate}}
  </view>

  <!-- ===== 分类标签（双行横向滚动） ===== -->
  <!-- scroll-view: 微信的可滚动容器，scroll-x 启用横向滚动 -->
  <scroll-view class="category-scroll" scroll-x enable-flex>
    <view class="category-rows">
      <!-- 第一行分类标签 -->
      <view class="category-row">
        <view
          wx:for="{{categoryRow1}}"
          wx:key="*this"
          class="tag {{activeCategory === item ? 'tag-active' : ''}}"
          bindtap="onCategoryTap"
          data-category="{{item}}"
        >{{item}}</view>
      </view>
      <!-- 第二行分类标签 -->
      <view class="category-row">
        <view
          wx:for="{{categoryRow2}}"
          wx:key="*this"
          class="tag {{activeCategory === item ? 'tag-active' : ''}}"
          bindtap="onCategoryTap"
          data-category="{{item}}"
        >{{item}}</view>
      </view>
    </view>
  </scroll-view>

  <!-- ===== 文件类型切换栏 ===== -->
  <view class="type-bar">
    <view
      wx:for="{{docTypes}}"
      wx:key="*this"
      class="type-item {{activeType === item ? 'type-active' : ''}}"
      bindtap="onTypeTap"
      data-type="{{item}}"
    >{{item}}</view>
  </view>

  <!-- ===== 文件列表 ===== -->
  <!-- 加载中 → 显示骨架屏（占位灰色方块） -->
  <skeleton wx:if="{{loading}}" count="{{4}}" />

  <!-- 加载完成 → 显示文件卡片列表 -->
  <view wx:else>
    <!-- file-card 自定义组件，遍历 documents 数组渲染 -->
    <file-card wx:for="{{documents}}" wx:key="id" doc="{{item}}" />

    <!-- 空状态提示 -->
    <view wx:if="{{documents.length === 0}}" class="empty">暂无文件</view>

    <!-- 加载更多按钮（hasMore 为真时显示） -->
    <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMore">
      ↓ 加载更多
    </view>

    <!-- 查看更多按钮（跳转分类列表页） -->
    <view class="view-more" bindtap="goCategory">
      查看更多 →
    </view>
  </view>
</view>
