/**
 * ===========================================================================
 * Agent 对话页 — 样式表
 * ===========================================================================
 * 主题色：政务蓝 #1a6fb5
 * 设计风格：跟随项目整体风格，简洁专业
 */

/* ===== 容器 ===== */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f0f2f5;
}

/* ===== 顶部新对话栏 ===== */
.new-chat-bar {
  display: flex;
  justify-content: center;
  padding: 12rpx 0;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.new-chat-btn {
  font-size: 26rpx;
  color: #1a6fb5;
  padding: 8rpx 32rpx;
  border: 1rpx solid #1a6fb5;
  border-radius: 32rpx;
}

/* ===== 消息列表 ===== */
.msg-list {
  flex: 1;
  padding: 16rpx 24rpx;
  overflow-y: auto;
}

.msg-bottom-spacer {
  height: 32rpx;
}

/* ===== 消息行 ===== */
.msg-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.msg-row--user {
  flex-direction: row-reverse;
}

/* ===== 头像 ===== */
.avatar {
  width: 64rpx;
  height: 64rpx;
  font-size: 36rpx;
  line-height: 64rpx;
  text-align: center;
  flex-shrink: 0;
  margin: 0 12rpx;
}

/* ===== 消息气泡 ===== */
.bubble {
  max-width: 600rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 1.6;
  word-break: break-all;
}

.bubble--ai {
  background: #fff;
  border-top-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.bubble--user {
  background: #1a6fb5;
  color: #fff;
  border-top-right-radius: 4rpx;
}

/* ===== 思考过程 ===== */
.thinking-block {
  margin-bottom: 16rpx;
}

.thinking-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  cursor: pointer;
}

.thinking-arrow {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
}

.thinking-last {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.thinking-detail {
  margin-top: 8rpx;
  padding: 12rpx 16rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
  border-left: 4rpx solid #1a6fb5;
}

.thinking-step {
  font-size: 22rpx;
  color: #888;
  line-height: 1.8;
}

/* ===== 加载动画 ===== */
.loading-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 0;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #bbb;
  animation: blink 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: 0s; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes blink {
  0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
  40% { opacity: 1; transform: scale(1); }
}

/* ===== 回答内容 ===== */
.msg-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.7;
  white-space: pre-line;
}

/* ===== 相关文件 ===== */
.related-docs {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.related-docs-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

/* ===== 底部输入栏 ===== */
.input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
}

.input-box {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.send-btn {
  flex-shrink: 0;
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  background: #f5f5f5;
  border-radius: 36rpx;
  border: none;
  padding: 0;
}

.send-btn--active {
  color: #fff;
  background: #1a6fb5;
}

.send-btn[disabled] {
  color: #ccc;
  background: #f5f5f5;
}
