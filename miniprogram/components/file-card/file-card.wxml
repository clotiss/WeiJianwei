<!--
============================================================================
file-card 组件模板 — 文件列表卡片
============================================================================

每个卡片显示：
  - 文件标题（最多 2 行，超出省略号）
  - 发文字号 + 发布日期（单行灰色文字）

bindtap="onTap" → 点击整个卡片跳转到详情页
-->

<view class="file-card" bindtap="onTap">
  <!-- 文件标题 -->
  <view class="title">{{doc.title}}</view>
  <!-- 元信息行：发文字号（如有）· 发布日期 -->
  <view class="meta">
    <text wx:if="{{doc.doc_number}}">{{doc.doc_number}} · </text>
    <text>{{doc.publish_date}}</text>
  </view>
</view>
